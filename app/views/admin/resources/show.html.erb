<div class="admin-page-header">
  <div class="admin-page-title">
    <span class="admin-kicker"><%= @resource_config.model_class.model_name.human %></span>
    <h1><%= t('admin.titles.show', resource: @resource_config.label) %></h1>
    <p><%= @record.to_param %></p>
  </div>
  <div class="admin-page-actions">
    <%= link_to admin_resources_path(@resource_config.key), class: 'btn admin-btn' do %>
      <i class="bi bi-arrow-left" aria-hidden="true"></i>
      <span><%= t('admin.actions.back_to_index') %></span>
    <% end %>
    <%= link_to admin_edit_resource_path(@resource_config.key, @record), class: 'btn admin-btn-primary' do %>
      <i class="bi bi-pencil" aria-hidden="true"></i>
      <span><%= t('admin.actions.edit') %></span>
    <% end %>
  </div>
</div>

<% member_actions = admin_resource_actions(@resource_config, record: @record) %>
<% if member_actions.any? %>
  <div class="admin-action-bar">
    <span><%= t('admin.actions.primary') %></span>
    <% member_actions.each do |action| %>
      <%= link_to admin_member_resource_action_path(@resource_config.key, @record, action.key), class: 'btn btn-sm admin-btn' do %>
        <i class="bi bi-lightning-charge" aria-hidden="true"></i>
        <span><%= action.label %></span>
      <% end %>
    <% end %>
  </div>
<% end %>

<div class="admin-panel admin-table-panel">
  <div class="table-responsive">
    <table class="table admin-detail-table mb-0">
      <tbody>
        <% @resource_config.model_class.columns.each do |column| %>
          <tr>
            <th><%= @resource_config.detail_attribute_label(column.name) %></th>
            <td><%= admin_display_value(@resource_config, @record, column.name) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="admin-danger-zone">
  <%= button_to admin_resource_path(@resource_config.key, @record), method: :delete, class: 'btn admin-btn-danger', form: { data: { turbo_confirm: t('admin.confirm.destroy') } } do %>
    <i class="bi bi-trash" aria-hidden="true"></i>
    <span><%= t('admin.actions.destroy') %></span>
  <% end %>
</div>

<div class="admin-section-heading">
  <h2><%= t('admin.relations.heading') %></h2>
</div>
<div class="admin-relation-grid">
  <% admin_relation_sections(@resource_config, @record).each do |section| %>
    <div class="admin-panel admin-relation-card">
        <div class="admin-relation-header">
          <span class="fw-semibold"><%= section.label %></span>
          <span class="admin-count-pill"><%= number_with_delimiter(section.count) %></span>
        </div>
        <div class="admin-relation-body">
          <% if section.empty? %>
            <p class="admin-empty"><%= t('admin.relations.empty') %></p>
          <% else %>
            <div class="admin-list-stack">
              <% section.records.each do |related_record| %>
                <div class="admin-resource-row">
                  <%= admin_relation_record_summary(related_record) %>
                  <% if section.associated_resource.present? %>
                    <%= link_to admin_resource_path(section.associated_resource.key, related_record), class: 'btn btn-sm admin-btn' do %>
                      <i class="bi bi-eye" aria-hidden="true"></i>
                      <span><%= t('admin.actions.show') %></span>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
    </div>
  <% end %>
</div>
