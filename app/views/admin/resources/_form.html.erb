<% if record.errors.any? %>
  <div class="alert alert-danger" role="alert">
    <p class="fw-bold mb-1"><%= t('admin.form.save_failed') %></p>
    <ul class="mb-0">
      <% record.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="card">
  <div class="card-body">
    <%= form_with scope: :record, url:, method: do |form| %>
      <% resource_config.attributes_for_form.each do |attribute| %>
        <%= admin_form_field(form, resource_config, record, attribute) %>
      <% end %>

      <div class="d-flex gap-2 pt-2">
        <%= form.submit t('admin.actions.save'), class: 'btn admin-btn' %>
        <%= link_to t('admin.actions.cancel'), record.persisted? ? admin_resource_path(resource_config.key, record) : admin_resources_path(resource_config.key), class: 'btn admin-btn' %>
      </div>
    <% end %>
  </div>
</div>
