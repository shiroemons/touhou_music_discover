<% if record.errors.any? %>
  <div class="alert alert-danger" role="alert">
    <p class="fw-bold mb-1"><%= t('admin.form.save_failed') %></p>
    <ul class="mb-0">
      <% record.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="admin-panel admin-form-panel">
  <div class="admin-form-body">
    <%= form_with scope: :record, url:, method: do |form| %>
      <% resource_config.attributes_for_form.each do |attribute| %>
        <%= admin_form_field(form, resource_config, record, attribute) %>
      <% end %>

      <div class="admin-form-actions">
        <%= form.button type: :submit, class: 'btn admin-btn-primary' do %>
          <i class="bi bi-check-lg" aria-hidden="true"></i>
          <span><%= t('admin.actions.save') %></span>
        <% end %>
        <%= link_to record.persisted? ? admin_resource_path(resource_config.key, record) : admin_resources_path(resource_config.key), class: 'btn admin-btn' do %>
          <i class="bi bi-x-lg" aria-hidden="true"></i>
          <span><%= t('admin.actions.cancel') %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
