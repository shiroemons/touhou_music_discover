<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
  <div>
    <h1 class="h3 mb-1"><%= @resource_config.label %></h1>
    <p class="text-body-secondary mb-0"><%= @resource_config.description %></p>
  </div>
  <%= link_to t('admin.actions.new_record'), admin_new_resource_path(@resource_config.key), class: 'btn admin-btn' %>
</div>

<% collection_actions = admin_resource_actions(@resource_config) %>
<% if collection_actions.any? %>
  <div class="admin-action-bar d-flex flex-wrap align-items-center gap-2 mb-3">
    <span class="text-body-secondary small"><%= t('admin.actions.heading') %></span>
    <% collection_actions.each do |action| %>
      <%= link_to action.label, admin_resource_action_path(@resource_config.key, action.key), class: 'btn btn-sm admin-btn' %>
    <% end %>
  </div>
<% end %>

<%= form_with url: admin_resources_path(@resource_config.key), method: :get, class: 'row g-2 align-items-center mb-3' do |form| %>
  <div class="col-12 col-md-6 col-xl-4">
    <%= form.search_field :q, value: params[:q], placeholder: t('admin.search.placeholder'), class: 'form-control' %>
  </div>
  <div class="col-auto">
    <%= form.submit t('admin.search.submit'), class: 'btn admin-btn' %>
  </div>
  <% if params[:q].present? %>
    <div class="col-auto">
      <%= link_to t('admin.search.clear'), admin_resources_path(@resource_config.key), class: 'btn admin-btn' %>
    </div>
  <% end %>
<% end %>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <% @resource_config.index_attributes.each do |attribute| %>
            <th><%= @resource_config.attribute_label(attribute) %></th>
          <% end %>
          <th class="text-end"><%= t('admin.table.actions') %></th>
        </tr>
      </thead>
      <tbody>
        <% @records.each do |record| %>
          <tr>
            <% @resource_config.index_attributes.each do |attribute| %>
              <td><%= admin_display_value(@resource_config, record, attribute) %></td>
            <% end %>
            <td class="text-end text-nowrap">
              <%= link_to t('admin.actions.show'), admin_resource_path(@resource_config.key, record), class: 'btn btn-sm admin-btn' %>
              <%= link_to t('admin.actions.edit'), admin_edit_resource_path(@resource_config.key, record), class: 'btn btn-sm admin-btn' %>
            </td>
          </tr>
        <% end %>
        <% if @records.empty? %>
          <tr>
            <td colspan="<%= @resource_config.index_attributes.size + 1 %>" class="text-center text-body-secondary py-5"><%= t('admin.table.empty') %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="mt-3">
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
</div>
