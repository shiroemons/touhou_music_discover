<div class="admin-page-header">
  <div class="admin-page-title">
    <span class="admin-kicker"><%= t('admin.dashboard.all_resources') %></span>
    <h1><%= @resource_config.label %></h1>
    <p><%= @resource_config.description %></p>
  </div>
  <div class="admin-page-actions">
    <%= link_to admin_new_resource_path(@resource_config.key), class: 'btn admin-btn-primary' do %>
      <i class="bi bi-plus-lg" aria-hidden="true"></i>
      <span><%= t('admin.actions.new_record') %></span>
    <% end %>
  </div>
</div>

<% collection_actions = admin_resource_actions(@resource_config) %>
<% if collection_actions.any? %>
  <div class="admin-action-bar">
    <span><%= t('admin.actions.primary') %></span>
    <% collection_actions.each do |action| %>
      <%= link_to admin_resource_action_path(@resource_config.key, action.key), class: 'btn btn-sm admin-btn' do %>
        <i class="bi bi-lightning-charge" aria-hidden="true"></i>
        <span><%= action.label %></span>
      <% end %>
    <% end %>
  </div>
<% end %>

<%= form_with url: admin_resources_path(@resource_config.key), method: :get, class: 'admin-search-form' do |form| %>
  <%= form.hidden_field :scroll, value: 'infinite' if admin_infinite_scroll? %>
  <% if @filters.any? %>
    <div class="admin-filter-bar">
      <span class="admin-filter-heading"><%= t('admin.filters.heading') %></span>
      <% @filters.each do |filter| %>
        <div class="admin-filter-field">
          <%= form.label "filters_#{filter[:attribute]}", filter[:label], class: 'form-label' %>
          <%= form.select "filters[#{filter[:attribute]}]",
                          options_for_select((filter[:include_blank] ? [[t('admin.filters.all'), '']] : []) + filter[:options].map { |value, label| [label, value] }, @active_filters[filter[:attribute]]),
                          {},
                          class: 'form-select',
                          id: "filters_#{filter[:attribute]}",
                          onchange: 'this.form.requestSubmit()' %>
        </div>
      <% end %>
    </div>
  <% end %>
  <div class="admin-search-input">
    <i class="bi bi-search" aria-hidden="true"></i>
    <%= form.search_field :q, value: params[:q], placeholder: t('admin.search.placeholder'), class: 'form-control' %>
  </div>
  <div class="admin-search-actions">
    <%= form.button type: :submit, class: 'btn admin-btn-primary' do %>
      <i class="bi bi-search" aria-hidden="true"></i>
      <span><%= t('admin.search.submit') %></span>
    <% end %>
    <% if admin_active_filters?(@resource_config, @active_filters) %>
      <%= link_to admin_clear_filters_path(@resource_config), class: 'btn admin-btn' do %>
        <i class="bi bi-x-lg" aria-hidden="true"></i>
        <span><%= t('admin.search.clear') %></span>
      <% end %>
    <% end %>
  </div>
<% end %>

<div class="admin-view-mode-bar" aria-label="<%= t('admin.scroll_mode.label') %>">
  <span class="admin-view-mode-label"><%= t('admin.scroll_mode.label') %></span>
  <div class="admin-view-mode-options">
    <%= link_to admin_scroll_mode_path(:pagination), class: "admin-view-mode-link #{'is-active' unless admin_infinite_scroll?}", aria: { current: admin_infinite_scroll? ? nil : 'true' } do %>
      <i class="bi bi-list-ol" aria-hidden="true"></i>
      <span><%= t('admin.scroll_mode.pagination') %></span>
    <% end %>
    <%= link_to admin_scroll_mode_path(:infinite), class: "admin-view-mode-link #{'is-active' if admin_infinite_scroll?}", aria: { current: admin_infinite_scroll? ? 'true' : nil } do %>
      <i class="bi bi-arrow-down-circle" aria-hidden="true"></i>
      <span><%= t('admin.scroll_mode.infinite') %></span>
    <% end %>
  </div>
</div>

<div class="admin-panel admin-table-panel"
     data-controller="<%= 'admin-infinite-scroll' if admin_infinite_scroll? %>"
     data-admin-infinite-scroll-enabled-value="<%= admin_infinite_scroll? %>"
     data-admin-infinite-scroll-next-url-value="<%= admin_infinite_scroll_next_url(@pagy) %>">
  <div class="table-responsive" data-admin-infinite-scroll-target="container">
    <table class="table table-hover align-middle admin-table mb-0">
      <thead>
        <tr>
          <% @resource_config.index_attributes.each do |attribute| %>
            <th><%= @resource_config.index_attribute_label(attribute) %></th>
          <% end %>
          <th class="text-end"><%= t('admin.table.actions') %></th>
        </tr>
      </thead>
      <tbody data-admin-infinite-scroll-target="rows">
        <% @records.each do |record| %>
          <tr>
            <% @resource_config.index_attributes.each do |attribute| %>
              <td><%= admin_index_display_value(@resource_config, record, attribute) %></td>
            <% end %>
            <td>
              <div class="admin-row-actions">
                <%= link_to admin_resource_path(@resource_config.key, record), class: 'btn btn-sm admin-btn', title: t('admin.actions.show') do %>
                  <i class="bi bi-eye" aria-hidden="true"></i>
                  <span><%= t('admin.actions.show') %></span>
                <% end %>
                <%= link_to admin_edit_resource_path(@resource_config.key, record), class: 'btn btn-sm admin-btn', title: t('admin.actions.edit') do %>
                  <i class="bi bi-pencil" aria-hidden="true"></i>
                  <span><%= t('admin.actions.edit') %></span>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @records.empty? %>
          <tr>
            <td colspan="<%= @resource_config.index_attributes.size + 1 %>" class="text-center text-body-secondary py-5"><%= t('admin.table.empty') %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if admin_infinite_scroll? && @pagy.next.present? %>
      <div class="admin-infinite-scroll-sentinel" data-admin-infinite-scroll-target="sentinel" aria-hidden="true"></div>
    <% end %>
  </div>
  <% if admin_infinite_scroll? %>
    <div class="admin-infinite-scroll-footer">
      <div class="admin-infinite-scroll-status"
           data-admin-infinite-scroll-target="status"
           data-loading-text="<%= t('admin.scroll_mode.loading') %>"
           data-ready-text="<%= t('admin.scroll_mode.ready') %>"
           data-complete-text="<%= t('admin.scroll_mode.complete') %>"
           data-error-text="<%= t('admin.scroll_mode.error') %>">
        <%= @pagy.next.present? ? t('admin.scroll_mode.ready') : t('admin.scroll_mode.complete') %>
      </div>
    </div>
  <% end %>
</div>

<% unless admin_infinite_scroll? %>
  <%= admin_pagination(@pagy) %>
<% end %>
