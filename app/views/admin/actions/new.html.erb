<div class="admin-page-header">
  <div class="admin-page-title">
    <span class="admin-kicker"><%= @resource_config.label %></span>
    <h1><%= @action.label %></h1>
    <p><%= @action.description %></p>
  </div>
  <div class="admin-page-actions">
    <%= link_to @record.present? ? admin_resource_path(@resource_config.key, @record) : admin_resources_path(@resource_config.key), class: 'btn admin-btn' do %>
      <i class="bi bi-x-lg" aria-hidden="true"></i>
      <span><%= t('admin.actions.cancel') %></span>
    <% end %>
  </div>
</div>

<div class="alert alert-warning admin-action-warning" role="alert">
  <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
  <%= t('admin.actions.confirmation') %>
</div>

<div class="admin-panel admin-form-panel">
  <div class="admin-form-body">
    <%= form_with scope: :fields,
                  url: @record.present? ? admin_member_resource_action_path(@resource_config.key, @record, @action.key) : admin_resource_action_path(@resource_config.key, @action.key),
                  method: :post,
                  multipart: true,
                  data: {
                    controller: 'admin-action-confirm',
                    action: 'submit->admin-action-confirm#submit'
                  } do |form| %>
      <% @action.fields.each do |field| %>
        <div class="admin-field">
          <%= form.label field.name, field.name.to_s.humanize, class: 'form-label' %>
          <% if field.type == :file %>
            <%= form.file_field field.name, class: 'form-control', required: field.required %>
          <% else %>
            <%= form.text_field field.name, class: 'form-control', required: field.required %>
          <% end %>
          <% if field.help.present? %>
            <div class="form-text"><%= field.help %></div>
          <% end %>
        </div>
      <% end %>

      <div class="admin-form-actions">
        <%= form.button type: :submit, class: 'btn admin-btn-danger' do %>
          <i class="bi bi-play-fill" aria-hidden="true"></i>
          <span><%= t('admin.actions.run') %></span>
        <% end %>
        <%= link_to @record.present? ? admin_resource_path(@resource_config.key, @record) : admin_resources_path(@resource_config.key), class: 'btn admin-btn' do %>
          <i class="bi bi-x-lg" aria-hidden="true"></i>
          <span><%= t('admin.actions.cancel') %></span>
        <% end %>
      </div>

      <div class="modal fade" tabindex="-1" aria-labelledby="admin-action-confirm-title" aria-hidden="true" data-admin-action-confirm-target="modal">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <div class="modal-header">
              <h2 class="modal-title fs-5" id="admin-action-confirm-title"><%= t('admin.actions.confirm_modal.title') %></h2>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="<%= t('admin.actions.confirm_modal.close') %>"></button>
            </div>
            <div class="modal-body">
              <p><%= t('admin.actions.confirmation') %></p>
              <strong><%= @action.label %></strong>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn admin-btn" data-bs-dismiss="modal">
                <i class="bi bi-x-lg" aria-hidden="true"></i>
                <span><%= t('admin.actions.cancel') %></span>
              </button>
              <button type="button" class="btn admin-btn-danger" data-action="admin-action-confirm#confirm">
                <i class="bi bi-play-fill" aria-hidden="true"></i>
                <span><%= t('admin.actions.run') %></span>
              </button>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
