<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
  <div>
    <h1 class="h3 mb-1"><%= @action.label %></h1>
    <p class="text-body-secondary mb-0"><%= @action.description %></p>
  </div>
  <%= link_to t('admin.actions.cancel'), @record.present? ? admin_resource_path(@resource_config.key, @record) : admin_resources_path(@resource_config.key), class: 'btn admin-btn' %>
</div>

<div class="alert alert-warning" role="alert">
  <%= t('admin.actions.confirmation') %>
</div>

<div class="card">
  <div class="card-body">
    <%= form_with scope: :fields, url: @record.present? ? admin_member_resource_action_path(@resource_config.key, @record, @action.key) : admin_resource_action_path(@resource_config.key, @action.key), method: :post, multipart: true do |form| %>
      <% @action.fields.each do |field| %>
        <div class="mb-3">
          <%= form.label field.name, field.name.to_s.humanize, class: 'form-label' %>
          <% if field.type == :file %>
            <%= form.file_field field.name, class: 'form-control', required: field.required %>
          <% else %>
            <%= form.text_field field.name, class: 'form-control', required: field.required %>
          <% end %>
          <% if field.help.present? %>
            <div class="form-text"><%= field.help %></div>
          <% end %>
        </div>
      <% end %>

      <div class="d-flex gap-2">
        <%= form.submit t('admin.actions.run'), class: 'btn admin-btn-danger', data: { turbo_confirm: t('admin.actions.confirmation') } %>
        <%= link_to t('admin.actions.cancel'), @record.present? ? admin_resource_path(@resource_config.key, @record) : admin_resources_path(@resource_config.key), class: 'btn admin-btn' %>
      </div>
    <% end %>
  </div>
</div>
