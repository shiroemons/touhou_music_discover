<div class="admin-action-page">
  <div class="admin-page-header admin-action-header">
    <div class="admin-page-title">
      <span class="admin-kicker"><%= @resource_config.label %></span>
      <h1><%= @action.label %></h1>
      <p><%= t('admin.actions.progress.description') %></p>
    </div>
    <div class="admin-page-actions">
      <%= link_to @action_run.fetch('redirect_path'), class: 'btn admin-btn' do %>
        <%= admin_icon(:arrow_left) %>
        <span><%= @record.present? ? t('admin.actions.back_to_show') : t('admin.actions.back_to_index') %></span>
      <% end %>
    </div>
  </div>

  <div class="admin-action-layout">
    <div
      class="admin-action-progress-shell"
      data-controller="admin-action-progress"
      data-admin-action-progress-url-value="<%= action_run_progress_path(@action_run.fetch('id')) %>"
      data-admin-action-progress-interval-value="1000"
    >
      <%= render 'progress', action_run: @action_run %>
    </div>

    <aside class="admin-action-side-panel">
      <div class="admin-panel admin-action-check-card">
        <div class="admin-panel-header">
          <h2><%= t('admin.actions.summary.heading') %></h2>
        </div>
        <div class="admin-action-target">
          <span><%= @resource_config.label %></span>
          <strong><%= @action.label %></strong>
        </div>
      </div>
      <div class="admin-panel admin-action-check-card">
        <div class="admin-panel-header">
          <h2><%= t('admin.actions.summary.checkpoints') %></h2>
        </div>
        <ul class="admin-action-checklist">
          <li>
            <%= admin_icon(:check_circle) %>
            <span><%= t('admin.actions.summary.progress') %></span>
          </li>
          <li>
            <%= admin_icon(:warning) %>
            <span><%= t('admin.actions.summary.external_api') %></span>
          </li>
        </ul>
      </div>
    </aside>
  </div>
</div>
