<% metrics = @dashboard_metrics %>
<% totals = metrics.fetch(:totals) %>
<% metric_path = lambda do |item|
     filters = item[:filters].presence
     filters.present? ? admin_resources_path(item.fetch(:resource_key), filters:) : admin_resources_path(item.fetch(:resource_key))
   end %>
<% segment_width = lambda do |segment|
     segment.fetch(:count).positive? && segment.fetch(:percent).zero? ? 0.4 : segment.fetch(:percent)
   end %>
<% segment_percent_label = lambda do |segment|
     if segment.fetch(:count).positive? && segment.fetch(:percent).zero?
       '0.1%未満'
     else
       number_to_percentage(segment.fetch(:percent), precision: 1, strip_insignificant_zeros: true)
     end
   end %>

<div class="admin-page-header">
  <div class="admin-page-title">
    <span class="admin-kicker"><%= t('admin.dashboard.overview') %></span>
    <h1><%= t('admin.dashboard.title') %></h1>
    <p><%= t('admin.dashboard.description') %></p>
  </div>
</div>

<div class="admin-stat-grid">
  <%= link_to admin_resources_path('albums'), class: 'admin-stat-card admin-stat-link' do %>
    <span class="admin-stat-label"><%= t('admin.dashboard.album_count') %></span>
    <strong><%= number_with_delimiter(totals.fetch(:albums)) %></strong>
    <span><%= t('admin.dashboard.touhou_album_breakdown', count: number_with_delimiter(totals.fetch(:touhou_albums))) %></span>
  <% end %>
  <%= link_to admin_resources_path('tracks'), class: 'admin-stat-card admin-stat-link' do %>
    <span class="admin-stat-label"><%= t('admin.dashboard.track_count') %></span>
    <strong><%= number_with_delimiter(totals.fetch(:tracks)) %></strong>
    <span><%= t('admin.dashboard.catalog_tracks') %></span>
  <% end %>
  <div class="admin-stat-card">
    <span class="admin-stat-label"><%= t('admin.dashboard.average_album_coverage') %></span>
    <strong><%= number_to_percentage(totals.fetch(:average_album_coverage), precision: 1, strip_insignificant_zeros: true) %></strong>
    <span><%= t('admin.dashboard.streaming_services') %></span>
  </div>
  <div class="admin-stat-card">
    <span class="admin-stat-label"><%= t('admin.dashboard.open_quality_issues') %></span>
    <strong><%= number_with_delimiter(totals.fetch(:open_quality_issues)) %></strong>
    <span><%= t('admin.dashboard.dashboard_generated_at', time: l(metrics.fetch(:generated_at), format: :short)) %></span>
  </div>
</div>

<% catalog_health = metrics.fetch(:catalog_health) %>
<section class="admin-panel admin-catalog-health-panel">
  <div class="admin-panel-header">
    <h2><%= t('admin.dashboard.catalog_health') %></h2>
  </div>

  <div class="admin-catalog-health-grid">
    <div class="admin-catalog-metric-grid">
      <% %i[missing_circle_albums missing_original_tracks original_or_other_tracks touhou_arrangement_tracks].each do |key| %>
        <% item = catalog_health.fetch(key) %>
        <%= link_to metric_path.call(item), class: "admin-catalog-metric-card is-#{item.fetch(:severity)}" do %>
          <span><%= item.fetch(:label) %></span>
          <strong><%= number_with_delimiter(item.fetch(:count)) %></strong>
          <small><%= item.fetch(:description) %></small>
        <% end %>
      <% end %>
    </div>

    <div class="admin-catalog-chart-grid">
      <div class="admin-catalog-chart">
        <h3><%= t('admin.dashboard.track_classification') %></h3>
        <div class="admin-stacked-bar" aria-label="<%= t('admin.dashboard.track_classification') %>">
          <% catalog_health.fetch(:track_segments).each do |segment| %>
            <span
              class="admin-stacked-bar-segment is-<%= segment.fetch(:tone) %>"
              style="width: <%= segment_width.call(segment) %>%"
              title="<%= "#{segment.fetch(:label)} #{number_with_delimiter(segment.fetch(:count))}件" %>"></span>
          <% end %>
        </div>
        <ul class="admin-chart-legend">
          <% catalog_health.fetch(:track_segments).each do |segment| %>
            <li class="is-<%= segment.fetch(:tone) %>">
              <span><%= segment.fetch(:label) %></span>
              <strong><%= number_with_delimiter(segment.fetch(:count)) %></strong>
              <small><%= segment_percent_label.call(segment) %></small>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="admin-catalog-chart">
        <h3><%= t('admin.dashboard.circle_assignment') %></h3>
        <div class="admin-stacked-bar" aria-label="<%= t('admin.dashboard.circle_assignment') %>">
          <% catalog_health.fetch(:circle_segments).each do |segment| %>
            <span
              class="admin-stacked-bar-segment is-<%= segment.fetch(:tone) %>"
              style="width: <%= segment_width.call(segment) %>%"
              title="<%= "#{segment.fetch(:label)} #{number_with_delimiter(segment.fetch(:count))}件" %>"></span>
          <% end %>
        </div>
        <ul class="admin-chart-legend">
          <% catalog_health.fetch(:circle_segments).each do |segment| %>
            <li class="is-<%= segment.fetch(:tone) %>">
              <span><%= segment.fetch(:label) %></span>
              <strong><%= number_with_delimiter(segment.fetch(:count)) %></strong>
              <small><%= segment_percent_label.call(segment) %></small>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="admin-panel admin-coverage-panel">
  <div class="admin-panel-header">
    <h2><%= t('admin.dashboard.streaming_coverage') %></h2>
  </div>

  <div class="admin-coverage-grid">
    <% metrics.fetch(:service_coverages).each do |coverage| %>
      <article class="admin-coverage-card is-<%= coverage.fetch(:key).to_s.dasherize %>">
        <div class="admin-coverage-heading">
          <h3><%= coverage.fetch(:label) %></h3>
          <span><%= t('admin.dashboard.album_track_completion', count: number_with_delimiter(coverage.fetch(:complete_album_tracks_count))) %></span>
        </div>

        <div class="admin-coverage-row">
          <div>
            <strong><%= t('admin.dashboard.albums') %></strong>
            <span><%= t('admin.dashboard.coverage_fraction', current: number_with_delimiter(coverage.fetch(:album_count)), total: number_with_delimiter(coverage.fetch(:album_total))) %></span>
          </div>
          <%= link_to number_to_percentage(coverage.fetch(:album_coverage_percent), precision: 1, strip_insignificant_zeros: true),
                      admin_resources_path('albums', filters: coverage.fetch(:missing_album_filter)),
                      class: 'admin-coverage-percent' %>
        </div>
        <div class="admin-meter" aria-hidden="true">
          <span style="width: <%= coverage.fetch(:album_coverage_percent) %>%"></span>
        </div>

        <div class="admin-coverage-row">
          <div>
            <strong><%= t('admin.dashboard.tracks') %></strong>
            <span><%= t('admin.dashboard.coverage_fraction', current: number_with_delimiter(coverage.fetch(:track_count)), total: number_with_delimiter(coverage.fetch(:track_total))) %></span>
          </div>
          <%= link_to number_to_percentage(coverage.fetch(:track_coverage_percent), precision: 1, strip_insignificant_zeros: true),
                      admin_resources_path('tracks', filters: coverage.fetch(:missing_track_filter)),
                      class: 'admin-coverage-percent' %>
        </div>
        <div class="admin-meter" aria-hidden="true">
          <span style="width: <%= coverage.fetch(:track_coverage_percent) %>%"></span>
        </div>

        <div class="admin-coverage-actions">
          <%= link_to admin_resources_path('albums', filters: coverage.fetch(:missing_album_filter)), class: 'admin-coverage-action' do %>
            <span><%= t('admin.dashboard.missing_albums') %></span>
            <strong><%= t('admin.dashboard.count_value', count: number_with_delimiter(coverage.fetch(:album_missing_count))) %></strong>
          <% end %>
          <%= link_to admin_resources_path('tracks', filters: coverage.fetch(:missing_track_filter)), class: 'admin-coverage-action is-danger' do %>
            <span><%= t('admin.dashboard.missing_tracks') %></span>
            <strong><%= t('admin.dashboard.count_value', count: number_with_delimiter(coverage.fetch(:track_missing_count))) %></strong>
          <% end %>
          <%= link_to admin_resources_path(coverage.fetch(:album_resource_key), filters: { track_status: 'incomplete' }), class: 'admin-coverage-action is-warning' do %>
            <span><%= t('admin.dashboard.incomplete_albums') %></span>
            <strong><%= t('admin.dashboard.count_value', count: number_with_delimiter(coverage.fetch(:incomplete_album_tracks_count))) %></strong>
          <% end %>
        </div>

        <div class="admin-coverage-fetch-actions">
          <%= link_to admin_resource_action_path(coverage.fetch(:missing_track_action_resource_key), coverage.fetch(:missing_track_action_key)),
                      class: 'btn btn-sm admin-btn-primary' do %>
            <%= admin_icon(:download) %>
            <span><%= t('admin.dashboard.fetch_missing_tracks') %></span>
          <% end %>
          <%= link_to admin_resources_path('tracks', filters: coverage.fetch(:missing_track_filter)),
                      class: 'btn btn-sm admin-btn' do %>
            <%= admin_icon(:list) %>
            <span><%= t('admin.dashboard.review_missing_tracks') %></span>
          <% end %>
        </div>

        <div class="admin-missing-track-preview">
          <div class="admin-missing-track-preview-header">
            <strong><%= t('admin.dashboard.missing_track_samples') %></strong>
            <%= link_to t('admin.dashboard.view_all'),
                        admin_resources_path('tracks', filters: coverage.fetch(:missing_track_filter)) %>
          </div>
          <% if coverage.fetch(:missing_track_samples).any? %>
            <div class="admin-missing-track-list">
              <% coverage.fetch(:missing_track_samples).each do |track| %>
                <%= link_to admin_resource_path('tracks', track.fetch(:id)), class: 'admin-missing-track-link' do %>
                  <span><%= track[:name].presence || track.fetch(:isrc) %></span>
                  <small><%= t('admin.dashboard.track_identity', jan_code: track.fetch(:jan_code), isrc: track.fetch(:isrc)) %></small>
                <% end %>
              <% end %>
            </div>
          <% else %>
            <p class="admin-missing-track-empty"><%= t('admin.dashboard.no_missing_tracks') %></p>
          <% end %>
        </div>
      </article>
    <% end %>
  </div>
</section>

<div class="admin-dashboard-grid">
  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2><%= t('admin.dashboard.work_queue') %></h2>
    </div>
    <div class="admin-list-stack admin-metric-list">
      <% if metrics.fetch(:work_queue).any? %>
        <% metrics.fetch(:work_queue).each do |item| %>
          <%= link_to metric_path.call(item), class: "admin-metric-row is-#{item.fetch(:severity)}" do %>
            <span>
              <strong><%= item.fetch(:label) %></strong>
              <small><%= item.fetch(:description) %></small>
            </span>
            <span class="admin-count-pill"><%= number_with_delimiter(item.fetch(:count)) %></span>
          <% end %>
        <% end %>
      <% else %>
        <p class="admin-empty"><%= t('admin.dashboard.no_work_queue') %></p>
      <% end %>
    </div>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2><%= t('admin.dashboard.data_quality') %></h2>
    </div>
    <div class="admin-list-stack admin-metric-list">
      <% if metrics.fetch(:data_quality).any? %>
        <% metrics.fetch(:data_quality).each do |item| %>
          <%= link_to metric_path.call(item), class: "admin-metric-row is-#{item.fetch(:severity)}" do %>
            <span>
              <strong><%= item.fetch(:label) %></strong>
              <small><%= item.fetch(:description) %></small>
            </span>
            <span class="admin-count-pill"><%= number_with_delimiter(item.fetch(:count)) %></span>
          <% end %>
        <% end %>
      <% else %>
        <p class="admin-empty"><%= t('admin.dashboard.no_quality_issues') %></p>
      <% end %>
    </div>
  </section>
</div>

<section class="admin-panel">
  <% playlist_sync = metrics.fetch(:playlist_sync) %>
  <div class="admin-panel-header">
    <h2><%= t('admin.dashboard.playlist_sync') %></h2>
    <%= link_to admin_resources_path(playlist_sync.fetch(:resource_key)), class: 'btn btn-sm admin-btn' do %>
      <%= admin_icon(:list) %>
      <span><%= t('admin.actions.index') %></span>
    <% end %>
  </div>

  <div class="admin-sync-grid">
    <div class="admin-sync-summary">
      <span class="admin-stat-label"><%= t('admin.dashboard.stale_playlists') %></span>
      <strong><%= number_with_delimiter(playlist_sync.fetch(:stale)) %></strong>
      <span><%= number_to_percentage(playlist_sync.fetch(:stale_percent), precision: 1, strip_insignificant_zeros: true) %></span>
    </div>
    <div class="admin-sync-details">
      <span><%= t('admin.dashboard.playlist_total', count: number_with_delimiter(playlist_sync.fetch(:total))) %></span>
      <span><%= t('admin.dashboard.playlist_synced', count: number_with_delimiter(playlist_sync.fetch(:synced))) %></span>
      <span><%= t('admin.dashboard.playlist_never_synced', count: number_with_delimiter(playlist_sync.fetch(:never_synced))) %></span>
      <span>
        <%= t(
              'admin.dashboard.playlist_latest_synced_at',
              time: playlist_sync.fetch(:latest_synced_at).present? ? l(playlist_sync.fetch(:latest_synced_at), format: :short) : t('admin.dashboard.no_updates')
            ) %>
      </span>
    </div>
  </div>
</section>

<section class="admin-panel">
  <div class="admin-panel-header">
    <h2><%= t('admin.dashboard.all_resources') %></h2>
  </div>

  <div class="admin-resource-grid">
    <% @resource_groups.each do |group_key, resources| %>
      <div class="admin-resource-group-card">
        <h3><%= t("admin.navigation.groups.#{group_key}") %></h3>
        <div class="admin-list-stack">
          <% resources.each do |resource| %>
            <% summary = @summary_by_key.fetch(resource.key) %>
            <div class="admin-resource-item">
              <div>
                <strong><%= resource.label %></strong>
                <small><%= resource.description %></small>
              </div>
              <div class="admin-resource-actions">
                <span class="admin-count-pill"><%= number_with_delimiter(summary[:count]) %></span>
                <%= link_to admin_resources_path(resource.key), class: 'btn btn-sm admin-btn', title: t('admin.actions.index') do %>
                  <%= admin_icon(:list) %>
                  <span><%= t('admin.actions.index') %></span>
                <% end %>
                <%= link_to admin_new_resource_path(resource.key), class: 'btn btn-sm admin-btn-primary', title: t('admin.actions.new_record') do %>
                  <%= admin_icon(:plus) %>
                  <span><%= t('admin.actions.new_record') %></span>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</section>
